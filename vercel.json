{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/app",
      "destination": "/static/index.html"
    },
    {
      "source": "/app/",
      "destination": "/static/index.html"
    },
    {
      "source": "/",
      "destination": "/static/index.html"
    }
  ]
}
